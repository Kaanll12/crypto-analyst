# ══════════════════════════════════════════════════════════════
#  CryptoAnalyst — Ortam Değişkenleri Şablonu
#  Bu dosyayı kopyalayın: cp .env.example .env
#  Gerçek değerleri .env dosyasına girin; .env GİT'E EKLEME!
# ══════════════════════════════════════════════════════════════

# ── UYGULAMA ──────────────────────────────────────────────────
# Çalışma ortamı: development | production
NODE_ENV=production

# Sunucu portu (Railway / Render otomatik atar, genellikle 3001)
PORT=3001

# ── GÜVENLİK ──────────────────────────────────────────────────
# JWT token imzalama sırrı — en az 32 karakter, rastgele üretin:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-me

# ── AI MOTORu ─────────────────────────────────────────────────
# Anthropic Claude API anahtarı — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── ÖDEME (Paddle) ────────────────────────────────────────────
# Paddle webhook imza sırrı (Paddle Dashboard → Notifications → Secret)
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...

# ── PUSH BİLDİRİMLERİ (VAPID) ────────────────────────────────
# Uygulama ilk çalışınca otomatik üretilir ve DB'ye kaydedilir.
# Üretim ortamında sabit kalması için aşağıya manuel ekleyebilirsiniz:
# node -e "const {createECDH}=require('crypto');const k=createECDH('prime256v1');k.generateKeys();console.log('PUB='+k.getPublicKey('base64url'));console.log('PRI='+k.getPrivateKey('base64url'))"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@crypto-analyst.app

# ── E-POSTA ───────────────────────────────────────────────────
# Seçenek 1: SMTP (Gmail, Yandex, vb.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="CryptoAnalyst <noreply@crypto-analyst.app>"

# Seçenek 2: SendGrid (SMTP_* yerine kullanın)
# SENDGRID_API_KEY=SG.xxxx

# ── ZAMANLAYICILAR (opsiyonel, varsayılanlar aktif) ───────────
# Günlük rapor oluşturma saati (cron formatı, TR saati)
DAILY_REPORT_CRON=0 9 * * *

# Haftalık e-posta özeti (her Pazartesi 08:00)
WEEKLY_DIGEST_CRON=0 8 * * 1

# ── FRONTEND / CORS ───────────────────────────────────────────
# Production domain (CORS whitelist)
ALLOWED_ORIGIN=https://your-domain.com

# Frontend statik dosya yolu (varsayılan: ../frontend)
# FRONTEND_PATH=../frontend

# ── RATE LİMİTER (opsiyonel) ──────────────────────────────────
# 15 dakikada maksimum istek sayısı (varsayılan: 100)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# ── VERİTABANI ────────────────────────────────────────────────
# SQLite dosya yolu (varsayılan: backend/data/crypto_analyst.db)
# DB_PATH=/app/data/crypto_analyst.db

# ── HATA TAKİBİ (opsiyonel) ───────────────────────────────────
# Sentry DSN — hata izleme servisi
# SENTRY_DSN=https://xxxx@sentry.io/yyyy
